{
  "server": {
    "name": "llbridge-dev",
    "environment": "development",
    "baseUrlEnv": "SERVER_API_BASE_URL",
    "healthcheckPath": "/api/health"
  },
  "auth": {
    "type": "bearer",
    "headerEnv": "SERVER_API_AUTH_HEADER",
    "schemeEnv": "SERVER_API_AUTH_SCHEME",
    "keyIdEnv": "SERVER_API_KEY_ID",
    "keyEnv": "SERVER_API_KEY"
  },
  "agent": {
    "defaultTimeoutMsEnv": "AGENT_DEFAULT_TIMEOUT_MS",
    "allowedActions": [
      "status",
      "healthcheck",
      "launch-lab",
      "collect-logs"
    ],
    "deniedActions": [
      "delete-data",
      "rotate-production-secret",
      "disable-security"
    ]
  },
  "audit": {
    "requireRequestId": true,
    "logAgentActions": true
  }
}
