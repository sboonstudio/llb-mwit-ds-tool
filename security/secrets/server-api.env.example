# Copy this file to server-api.env.local and fill real values on the target server only.

SERVER_API_ENV=development
SERVER_API_NAME=llbridge-dev
SERVER_API_BASE_URL=http://localhost:3000

# Authentication
SERVER_API_AUTH_TYPE=bearer
SERVER_API_AUTH_HEADER=Authorization
SERVER_API_AUTH_SCHEME=Bearer
SERVER_API_KEY_ID=replace-with-key-id
SERVER_API_KEY=replace-with-server-api-key

# Optional signing / webhook secret
SERVER_API_WEBHOOK_SECRET=replace-with-webhook-secret

# Agent behavior
AGENT_DEFAULT_TIMEOUT_MS=30000
AGENT_ALLOWED_ACTIONS=status,healthcheck,launch-lab,collect-logs
AGENT_DENIED_ACTIONS=delete-data,rotate-production-secret,disable-security
