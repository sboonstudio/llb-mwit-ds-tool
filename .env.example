# --- Local Development Defaults ---
NEXTJS_PORT=3000
JUPYTERHUB_PORT=8000
LLBRIDGE_LOCAL_URL=http://localhost:3000
JUPYTERHUB_LOCAL_URL=http://localhost:8000

# --- Authentication & Secrets ---
AUTH_SECRET=change-me-generate-a-long-random-value
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
JUPYTERHUB_SHARED_SECRET=change-me-generate-a-long-random-value
JUPYTERHUB_CRYPT_KEY=5d2f6c9e8a7b4c3d1e0f9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c4d3e2f1a0b9c8d
AUTH_TRUST_HOST=true

# --- Database & Storage ---
# SQLite (Default)
DATABASE_URL=file:/app/data/dev.db

# PostgreSQL (Future Upgrade)
# DATABASE_URL=postgresql://llbridge:llbridge_pass@llbridge-db-pg:5432/llbridge?schema=public
# POSTGRES_USER=llbridge
# POSTGRES_PASSWORD=llbridge_pass
# POSTGRES_DB=llbridge

JUPYTER_SINGLEUSER_IMAGE=jupyter/datascience-notebook:latest
JUPYTERHUB_START_TIMEOUT=900
JUPYTERHUB_HTTP_TIMEOUT=120

# --- Project Paths (Auto-synced by scripts) ---
LLBRIDGE_PROJECT_ROOT=<clone-root>
JUPYTERHUB_HOST_WORKSPACES=<clone-root>/infrastructure/data/lab-workspaces
JUPYTERHUB_HOST_SHARED_CONTENT=<clone-root>/infrastructure/content/sample-notebooks
JUPYTERHUB_HOST_SINGLEUSER_CONFIG=<clone-root>/infrastructure/lab/jupyterlab/singleuser-config
JUPYTERHUB_CONTAINER_WORKSPACES=/srv/jupyterhub/workspaces
JUPYTERHUB_SERVICE_NAME=llbridge-hub
DOCKER_NETWORK_NAME=sboon-llb-main-core_default
COMPOSE_PROJECT_NAME=sboon-llb-main-core

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# --- Initial Admin Setup ---
INITIAL_ADMIN_EMAIL=admin@sboon.org
INITIAL_ADMIN_PASSWORD=admin543

# --- Dynamic Public URLs (Managed by scripts/up.*) ---
# When running without Cloudflare (--local), these will default to localhost.
LLBRIDGE_PUBLIC_URL=http://localhost:3000
LLBRIDGE_PUBLIC_BASE_URL=http://localhost:3000
JUPYTERHUB_BASE_URL=http://localhost:8000
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
